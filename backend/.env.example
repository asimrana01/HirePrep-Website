GROQ_API_KEY=your_groq_api_key_here
SECRET_KEY=change_this_to_a_random_secret_string

# --- Firebase (Firestore only — Storage not used) ---
# Local development: download a service account key from Firebase Console
# (Project Settings -> Service Accounts -> Generate New Private Key), save it
# somewhere OUTSIDE this repo, and point to it here:
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# On Render, instead of a file path, paste the ENTIRE contents of the
# service account JSON file into this one env var instead:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# NOTE: FIREBASE_STORAGE_BUCKET is no longer needed — Storage has been
# removed. Only Firestore is used for data persistence.
